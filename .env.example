# 阿里云百炼 DashScope API Key
# qwen-vl-plus（多模态识图）+ qwen-plus（纯文本）共用一个 Key
# 申请地址: https://dashscope.console.aliyun.com/
DASHSCOPE_BASE_URL=your-base-url-here
DASHSCOPE_API_KEY=your-api-key-here

# Embedding 模型（OpenAI 兼容模式，复用上面的 DASHSCOPE_BASE_URL + /embeddings）
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIM=1024

# 高德地图 API Key（Web服务）
# 申请地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=your-api-key-here

# DeepSeek 官方 API Key（后续可能切换，暂不使用）
# DEEPSEEK_API_KEY=your-api-key-here

# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Agent 参数
MAX_REACT_STEPS=10
MAX_REFLECTION_RETRIES=3
REQUEST_TIMEOUT=30
